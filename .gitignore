# pyenv
#   For a library or package, you might want to ignore these files since the Python version is
#   controlled by the user. However, for an application, you should track them.
# .python-version

# pipenv
#   According to pypa/pipenv#1191, it is recommended to not commit Pipfile.lock into libraries.
#   For applications, you should track it.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, it is generally recommended to include poetry.lock in applications.
# poetry.lock

# pdm
#   Similar to Pipfile.lock, it is generally recommended to include pdm.lock in applications.
# pdm.lock

# PEP 582; used by e.g. github.com/pdm-project/pdm
